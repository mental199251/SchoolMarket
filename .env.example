FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=true

MONGO_URI=mongodb://127.0.0.1:27017/?directConnection=true
MONGO_DB_NAME=school_market
MONGO_TIMEOUT_MS=2000

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_SECRET_KEY=replace-with-a-random-secret
JWT_EXPIRES_SECONDS=604800
PASSWORD_MIN_LENGTH=8
UPLOAD_FOLDER=server/uploads
MAX_CONTENT_LENGTH=10485760
UPLOAD_IMAGE_MAX_BYTES=5242880

# AI uses the local Ollama HTTP API. Cloud models do not need an API key here:
# install Ollama on the backend machine, run `ollama signin`, then keep `ollama serve` running.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:120b-cloud
# For a fully local model, use a local model name instead, for example:
# OLLAMA_MODEL=qwen2.5:7b
OLLAMA_CONNECT_TIMEOUT_SECONDS=3
OLLAMA_RESPONSE_TIMEOUT_SECONDS=20
